# Anthropic API key for Claude predictions
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: override default model
# BOATRACE_MODEL=claude-sonnet-4-20250514

# Optional: SQLite database path (default: ~/.boatrace-ai/boatrace.db)
# BOATRACE_DB_PATH=/path/to/boatrace.db

# note.com settings (required for publish commands)
# NOTE_EMAIL=your@email.com
# NOTE_PASSWORD=your_password
# NOTE_USER_ID=your_note_user_id

# Optional: article price in JPY (default: 300)
# NOTE_ARTICLE_PRICE=300

# Optional: session file path (default: ~/.boatrace-ai/note_session.json)
# NOTE_SESSION_PATH=/path/to/note_session.json

# Optional: pre-exported session cookies (JSON) — CI用、CAPTCHA回避
# boatrace note export-session で取得 → GitHub Secrets に設定
# NOTE_SESSION_COOKIES={"cookies":{...},"xsrf_token":"..."}

# Anti-ban: humanized delays between posts (seconds)
# NOTE_PUBLISH_DELAY_MIN=120
# NOTE_PUBLISH_DELAY_MAX=300

# Daily publish cap
# NOTE_DAILY_PUBLISH_CAP=5
# NOTE_PREMIUM_CAP=3

# Cron startup jitter (seconds, 0 to disable)
# NOTE_CRON_JITTER_MAX=600

# Hashtag rotation count
# NOTE_HASHTAG_COUNT_MIN=4
# NOTE_HASHTAG_COUNT_MAX=6

# Follow settings
# NOTE_FOLLOW_MAX_PER_DAY=5
# NOTE_FOLLOW_DELAY_MIN=60
# NOTE_FOLLOW_DELAY_MAX=180
# NOTE_FOLLOW_MAX_TAGS=2

# Google Gemini image generation (optional, for AI eyecatch images)
# GOOGLE_API_KEY=your_api_key_here
# GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# GEMINI_EYECATCH_ENABLED=true

# X (Twitter) API settings (required for tweet commands)
# TWITTER_API_KEY=your_api_key
# TWITTER_API_SECRET=your_api_secret
# TWITTER_ACCESS_TOKEN=your_access_token
# TWITTER_ACCESS_SECRET=your_access_secret
